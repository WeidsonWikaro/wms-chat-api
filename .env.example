PORT=3001
CORS_ORIGIN=http://localhost:3000

# JWT — Socket.IO /chat handshake (`auth.token`) e POST /api/chat/dev-token
JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN=7d

# Apenas desenvolvimento: expõe POST /api/chat/dev-token (nunca true em produção)
# CHAT_DEV_TOKEN_ENDPOINT=true

# Swagger UI (with global prefix /api): http://localhost:3001/api/docs

# PostgreSQL (compose: porta host 5433 → 5432 no container)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=chat_api

# true = TypeORM creates/updates tables from entities (dev only). Use migrations in production and set false.
DB_SYNC=true

# true = log SQL to console (verbose)
DB_LOGGING=false

# Google Gemini (LangChain) — crie em https://aistudio.google.com/apikey
# GOOGLE_API_KEY=
# Modelos opcionais — defaults centralizados no código (não duplicar aqui salvo override):
#   LLM_GOOGLE_MODEL → src/modules/llm/llm.constants.ts (DEFAULT_LLM_GOOGLE_MODEL)
#   GEMINI_EMBEDDING_MODEL → src/modules/rag/rag.constants.ts (DEFAULT_GEMINI_EMBEDDING_MODEL)
# LLM_GOOGLE_MODEL=
#
# Limites do assistente (LangGraph): ver defaults em src/modules/llm/llm.constants.ts
# LLM_TURN_TIMEOUT_MS=90000
# LLM_MODEL_CALL_TIMEOUT_MS=60000
# LLM_TOOL_NODE_TIMEOUT_MS=45000
# LLM_MAX_TOOL_ROUNDS=8
# LLM_MAX_SAME_TOOL_STREAK=2
# LLM_RECURSION_LIMIT=40
# Desativar timeout fino do modelo ou das tools: use 0
# LLM_MODEL_CALL_TIMEOUT_MS=0
# LLM_TOOL_NODE_TIMEOUT_MS=0
# GEMINI_EMBEDDING_MODEL=
# RAG_VECTOR_DIMENSIONS=768 (opcional — força dim da coluna vector; senão faz probe na API)
# Pasta Markdown para indexar: yarn rag:ingest
# RAG_DOCS_PATH=docs
# Timeout da busca RAG (embedding + pgvector), ms. Omitir = default 30s; 0 = sem Promise.race nesta camada
# RAG_SEARCH_TIMEOUT_MS=30000

# LangSmith (opcional — tracing LangChain; ver https://docs.smith.langchain.com/)
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=
# LANGCHAIN_PROJECT=chat-api


#LangSmith variables
#LANGSMITH_TRACING=true
#LANGSMITH_ENDPOINT=https://api.smith.langchain.com
#LANGSMITH_API_KEY=<your-langsmith-api-key>
#LANGSMITH_PROJECT="pr-sparkling-teletype-71"
#OPENAI_API_KEY=<your-openai-api-key>
